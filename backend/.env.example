# Backend environment variables
# The backend reads different env vars depending on NODE_ENV:
#   - development: uses MONGODB_URI (local MongoDB)
#   - production:  uses MONGODB_URI_ATLAS (MongoDB Atlas)
# Vercel sets NODE_ENV=production automatically.

# Server port (Vercel ignores this, uses its own port internally)
PORT=5000

# Development: local MongoDB
MONGODB_URI=mongodb://localhost:27017/hospital

# Production: MongoDB Atlas connection string
# Get this from MongoDB Atlas → Database → Connect → Drivers
MONGODB_URI_ATLAS=mongodb+srv://user:pass@cluster.mongodb.net/hospital

# Environment: 'development' or 'production'
NODE_ENV=development
