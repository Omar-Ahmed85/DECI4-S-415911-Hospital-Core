# Appointment microservice environment variables
# The appointment service reads different env vars depending on NODE_ENV:
#   - development: uses APPOINTMENT_MONGODB_URI (local MongoDB)
#   - production:  uses APPOINTMENT_MONGODB_URI_ATLAS (MongoDB Atlas)
# Vercel sets NODE_ENV=production automatically.

# Server port (Vercel ignores this, uses its own port internally)
APPOINTMENT_SERVICE_PORT=5001

# Development: local MongoDB
APPOINTMENT_MONGODB_URI=mongodb://localhost:27017/hospital-appointments

# Production: MongoDB Atlas connection string
# Use the same Atlas cluster as backend, but with a different database name
APPOINTMENT_MONGODB_URI_ATLAS=mongodb+srv://user:pass@cluster.mongodb.net/hospital-appointments
NODE_ENV=development