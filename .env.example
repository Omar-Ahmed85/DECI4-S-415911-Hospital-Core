# Hospital Core — Environment Variables Template
# Copy to per-service .env files and fill in real values.
# Real .env files are gitignored — NEVER commit them.

# --- Backend (backend/.env) ---
# Reads MONGODB_URI (local) or MONGODB_URI_ATLAS (Atlas) depending on NODE_ENV.
PORT=5000
MONGODB_URI=mongodb://localhost:27017/hospital
MONGODB_URI_ATLAS=mongodb+srv://user:pass@cluster.mongodb.net/hospital
NODE_ENV=development

# --- Appointment microservice (appointment-service/.env) ---
# Reads APPOINTMENT_MONGODB_URI (local) or APPOINTMENT_MONGODB_URI_ATLAS (Atlas) depending on NODE_ENV.
APPOINTMENT_SERVICE_PORT=5001
APPOINTMENT_MONGODB_URI=mongodb://localhost:27017/hospital-appointments
APPOINTMENT_MONGODB_URI_ATLAS=mongodb+srv://user:pass@cluster.mongodb.net/hospital-appointments

# --- Frontend (frontend/.env) — MUST use the VITE_ prefix; Vite ignores everything else ---
# Set these in the Netlify dashboard to your Vercel URLs for production deploys.
VITE_API_URL=http://localhost:5000/api
VITE_APPOINTMENT_API_URL=http://localhost:5001/api
