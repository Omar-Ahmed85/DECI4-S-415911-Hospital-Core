# Frontend environment variables — VITE_ prefix REQUIRED by Vite
# These are baked into the JS bundle at BUILD time. To change them in production,
# set them in Netlify → Site settings → Environment variables, then trigger a redeploy.
#
# Development:  defaults to localhost (see frontend/src/api/client.js and appointmentClient.js)
# Production:   set these in Netlify dashboard to your Vercel deployment URLs
#
# Example for production:
#   VITE_API_URL=https://your-backend.vercel.app/api
#   VITE_APPOINTMENT_API_URL=https://your-appointment-service.vercel.app/api

VITE_API_URL=http://localhost:5000/api
VITE_APPOINTMENT_API_URL=http://localhost:5001/api
